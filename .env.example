# Coolify
COOLIFY_URL=https://your-coolify-instance.com
COOLIFY_TOKEN=your-coolify-api-token
# API version — change only if your Coolify instance uses a different API version
COOLIFY_API_VERSION=v1

# Server
PORT=3069

# Firebase Admin (server-side — Firebase Console > Project settings > Service accounts > Generate new private key)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-firebase-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# The email auto-promoted to super_admin on first login
SUPER_ADMIN_EMAIL=you@example.com

# Email domain restriction — leave empty to allow any Google account to sign in.
# Set to a domain (without @) to restrict logins to that domain only, e.g. "acme.com".
ALLOWED_EMAIL_DOMAIN=

# Database — Prisma ORM. Set DB_PROVIDER + DATABASE_URL together; the startup script
# populates schema.prisma from the template and regenerates the client automatically.
#
#   SQLite (default):  DB_PROVIDER=sqlite       DATABASE_URL=file:./data/shippr.db
#   MySQL:             DB_PROVIDER=mysql         DATABASE_URL=mysql://user:pass@host:3306/shippr
#   PostgreSQL:        DB_PROVIDER=postgresql    DATABASE_URL=postgresql://user:pass@host:5432/shippr
DB_PROVIDER=sqlite
DATABASE_URL=file:./data/shippr.db

# CORS — comma-separated list of allowed origins
# In production with the single-container setup, this can be left empty or set to your domain
CORS_ORIGINS=http://localhost:5173

# Firebase Web SDK (client-side — Firebase Console > Project settings > Your apps > Web app)
# Note: no VITE_ prefix here — the compose files map these to VITE_* build args at build time
FIREBASE_API_KEY=your-firebase-web-api-key
FIREBASE_AUTH_DOMAIN=your-firebase-project-id.firebaseapp.com
FIREBASE_STORAGE_BUCKET=your-firebase-project-id.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
FIREBASE_APP_ID=your-firebase-app-id
# FIREBASE_PROJECT_ID is already defined above (server and client share it)

# Optional: show only accounts from this domain on the Google sign-in screen.
# This is a UI hint only — access enforcement is done by ALLOWED_EMAIL_DOMAIN on the server.
GOOGLE_HD=
